{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "easy-mega-menu/mega-menu",
  ""version": "1.3.0",": "1.2.5",
  "title": "Easy Mega Menu",
  "category": "widgets",
  "icon": "menu",
  "description": "Display a mega menu built visually in the Easy Mega Menu admin.",
  "attributes": {
    "menuId": {
      "type": "string",
      "default": ""
    }
  },
  "supports": {
    "align": ["wide", "full"],
    "html": false
  },
  "textdomain": "easy-mega-menu",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "viewScript": "file:./view.js",
  "render": "file:./render.php"
}
